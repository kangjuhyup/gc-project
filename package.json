{
  "name": "gc-project",
  "version": "1.0.0",
  "description": "GC메디아이 과제 전형",
  "private": true,
  "license": "ISC",
  "author": "kangjuhyup",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:apps": "pnpm -r --parallel --filter @gc-project/service --filter @gc-project/ui dev",
    "dev:local": "pnpm run compose:up && pnpm run dev:apps",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "fast-check": "^4.7.0",
    "fishery": "^2.4.0"
  }
}
