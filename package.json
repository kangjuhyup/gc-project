{
  "name": "gc-project",
  "version": "1.0.0",
  "description": "GC메디아이 과제 전형",
  "private": true,
  "license": "ISC",
  "author": "kangjuhyup",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:apps": "pnpm -r --parallel --filter @gc-project/service --filter @gc-project/ui dev",
    "dev:service": "pnpm --filter @gc-project/service dev",
    "dev:service:all": "sh -c 'pnpm run dev:service & pnpm run dev:service:worker & wait'",
    "dev:service:worker": "pnpm --filter @gc-project/service dev:worker",
    "dev:worker": "pnpm --filter @gc-project/service dev:worker",
    "dev:ui": "pnpm --filter @gc-project/ui dev",
    "dev:ui:mock": "VITE_API_MODE=mock pnpm --filter @gc-project/ui dev",
    "dev:ui:real": "VITE_API_MODE=real pnpm --filter @gc-project/ui dev",
    "dev:local": "pnpm run compose:up && pnpm run dev:apps",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "service": "pnpm --filter @gc-project/service start",
    "service:all": "sh -c 'pnpm run service & pnpm run service:worker & wait'",
    "service:worker": "pnpm --filter @gc-project/service start:worker",
    "worker": "pnpm --filter @gc-project/service start:worker",
    "service:test:e2e": "sh scripts/service-e2e.sh",
    "prepare": "husky",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^8.57.1",
    "@faker-js/faker": "^10.4.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "fast-check": "^4.7.0",
    "fishery": "^2.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.1"
  }
}
