{
  "name": "@gc-project/service",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "NODE_ENV=development nest start --watch --entryFile api-main",
    "dev:api": "NODE_ENV=development nest start --watch --entryFile api-main",
    "dev:worker": "NODE_ENV=development nest start --watch --entryFile worker-main",
    "start": "node dist/api-main.js",
    "start:api": "node dist/api-main.js",
    "start:worker": "node dist/worker-main.js",
    "build": "nest build",
    "docs:openapi": "ts-node -r tsconfig-paths/register scripts/generate-openapi.ts",
    "test": "vitest run --reporter=verbose",
    "test:e2e": "vitest run --config vitest.e2e.config.ts --reporter=verbose",
    "test:coverage": "vitest run --coverage --reporter=verbose",
    "lint": "echo \"No service lint configured\""
  },
  "dependencies": {
    "@kangjuhyup/rvlog": "0.1.1",
    "@kangjuhyup/rvlog-nest": "0.1.1",
    "@mikro-orm/core": "^6.5.0",
    "@mikro-orm/migrations": "6.6.13",
    "@mikro-orm/nestjs": "^6.1.0",
    "@mikro-orm/postgresql": "^6.5.0",
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "ioredis": "^5.8.2",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@mikro-orm/better-sqlite": "6.6.13",
    "@nestjs/cli": "11.0.21",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "better-sqlite3": "11.10.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "vitest": "^4.0.17"
  }
}
