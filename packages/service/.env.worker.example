# Runtime
NODE_ENV=development
LOG_LEVEL=INFO

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gc_project
DB_USER=gc_user
DB_PASSWORD=gc_password

# Redis
REDIS_URL=redis://localhost:6379

# Address search
ADDRESS_SEARCH_ADAPTER=local
JUSO_API_KEY=

# Auth
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600
PHONE_NUMBER_ENCRYPTION_KEY=change-me-phone-number-encryption-key

# Seat hold
SEAT_HOLD_TTL_SECONDS=600

# Local payment adapter
LOCAL_PAYMENT_CALLBACK_URL=http://localhost:3000/payments/callback
LOCAL_PAYMENT_CALLBACK_DELAY_SECONDS=3

# Migrations
MIGRATIONS_RUN_ON_STARTUP=false

# Worker
PAYMENT_OUTBOX_WORKER_ENABLED=true
PAYMENT_OUTBOX_WORKER_INTERVAL_MS=1000
