{
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "description": "애플리케이션 프로세스가 요청을 처리할 수 있는지 확인합니다. 로드밸런서/헬스체크 용도로 사용합니다.",
        "operationId": "HealthController_getHealth",
        "parameters": [],
        "responses": {
          "200": {
            "description": "서비스가 정상 응답함",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatusDto"
                }
              }
            }
          }
        },
        "summary": "서비스 상태 확인",
        "tags": [
          "Health"
        ]
      }
    },
    "/members/check-user-id": {
      "get": {
        "description": "회원가입 전에 userId가 이미 사용 중인지 확인합니다. available=true이면 가입에 사용할 수 있습니다.",
        "operationId": "MemberController_checkUserId",
        "parameters": [
          {
            "name": "userId",
            "required": true,
            "in": "query",
            "description": "중복 여부를 확인할 회원 로그인 ID. 소문자로 시작하고 소문자/숫자/_ 조합 4~20자",
            "schema": {
              "pattern": "^[a-z][a-z0-9_]{3,19}$",
              "example": "movie_user",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "회원 아이디 사용 가능 여부",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckUserIdAvailabilityResultDto"
                }
              }
            }
          },
          "400": {
            "description": "userId 형식이 유효하지 않은 경우"
          }
        },
        "summary": "회원 아이디 중복 검사",
        "tags": [
          "Members"
        ]
      }
    },
    "/phone-verifications": {
      "post": {
        "description": "휴대전화번호 인증을 시작합니다. 실제 SMS 발송 대신 개발용 인증 코드를 응답으로 반환합니다.",
        "operationId": "MemberController_requestPhoneVerification",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestPhoneVerificationRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "휴대전화 인증 코드 발급 완료",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PhoneVerificationIssuedDto"
                }
              }
            }
          },
          "400": {
            "description": "휴대전화번호 형식이 유효하지 않은 경우"
          }
        },
        "summary": "휴대전화 인증 코드 발급",
        "tags": [
          "Members"
        ]
      }
    },
    "/phone-verifications/confirm": {
      "post": {
        "description": "발급된 인증 코드와 휴대전화번호를 검증하고 인증을 완료합니다.",
        "operationId": "MemberController_confirmPhoneVerification",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConfirmPhoneVerificationRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "휴대전화 인증 확인 결과",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PhoneVerificationConfirmedDto"
                }
              }
            }
          },
          "400": {
            "description": "인증 요청이 없거나, 만료되었거나, 코드가 일치하지 않는 경우"
          }
        },
        "summary": "휴대전화 인증 코드 확인",
        "tags": [
          "Members"
        ]
      }
    },
    "/members/signup": {
      "post": {
        "description": "아이디 중복, 휴대전화 인증 완료 여부를 검증한 뒤 회원을 생성합니다.",
        "operationId": "MemberController_signup",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupMemberRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "회원가입 완료",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SignupMemberResultDto"
                }
              }
            }
          },
          "400": {
            "description": "입력값이 유효하지 않거나 휴대전화 인증이 완료되지 않은 경우"
          },
          "409": {
            "description": "회원 아이디 또는 휴대전화번호가 이미 사용 중인 경우"
          }
        },
        "summary": "회원가입",
        "tags": [
          "Members"
        ]
      }
    },
    "/members/login": {
      "post": {
        "description": "회원 아이디와 비밀번호를 검증합니다. 비밀번호 실패가 5회 누적되면 회원이 잠금 상태가 됩니다.",
        "operationId": "MemberController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginMemberRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "로그인 성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginMemberResultDto"
                }
              }
            }
          },
          "400": {
            "description": "아이디/비밀번호가 일치하지 않거나 입력값이 유효하지 않은 경우"
          },
          "403": {
            "description": "비밀번호 실패 5회 누적으로 잠긴 회원인 경우"
          },
          "404": {
            "description": "회원을 찾을 수 없는 경우"
          }
        },
        "summary": "로그인",
        "tags": [
          "Members"
        ]
      }
    },
    "/members/temporary-password": {
      "post": {
        "description": "휴대전화 인증이 완료된 회원에게 임시비밀번호를 발급하고 잠금 상태를 해제합니다.",
        "operationId": "MemberController_issueTemporaryPassword",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IssueTemporaryPasswordRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "임시비밀번호 발급 완료",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemporaryPasswordIssuedDto"
                }
              }
            }
          },
          "400": {
            "description": "휴대전화 인증이 완료되지 않았거나 입력값이 유효하지 않은 경우"
          },
          "404": {
            "description": "회원을 찾을 수 없는 경우"
          }
        },
        "summary": "임시비밀번호 발급",
        "tags": [
          "Members"
        ]
      }
    },
    "/members/password": {
      "post": {
        "description": "기존 비밀번호 검증이 통과하면 신규 비밀번호로 변경합니다.",
        "operationId": "MemberController_changePassword",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangeMemberPasswordRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "비밀번호 변경 완료",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemberPasswordChangedDto"
                }
              }
            }
          },
          "400": {
            "description": "기존 비밀번호가 일치하지 않거나 입력값이 유효하지 않은 경우"
          },
          "404": {
            "description": "회원을 찾을 수 없는 경우"
          }
        },
        "summary": "비밀번호 변경",
        "tags": [
          "Members"
        ]
      }
    },
    "/api/addresses": {
      "get": {
        "description": "공공 주소 API를 통해 주소를 검색합니다. 회원가입 화면의 주소 선택 모달에서 사용합니다.",
        "operationId": "AddressController_search",
        "parameters": [
          {
            "name": "keyword",
            "required": true,
            "in": "query",
            "description": "주소 검색 키워드",
            "schema": {
              "minLength": 2,
              "maxLength": 80,
              "example": "테헤란로 427",
              "type": "string"
            }
          },
          {
            "name": "currentPage",
            "required": false,
            "in": "query",
            "description": "공공 주소 API 현재 페이지 번호",
            "schema": {
              "minimum": 1,
              "default": 1,
              "example": 1,
              "type": "number"
            }
          },
          {
            "name": "countPerPage",
            "required": false,
            "in": "query",
            "description": "페이지당 주소 검색 결과 수",
            "schema": {
              "minimum": 1,
              "maximum": 50,
              "default": 10,
              "example": 10,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "주소 검색 결과",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddressSearchResultDto"
                }
              }
            }
          },
          "400": {
            "description": "검색어 길이/페이지 파라미터가 유효하지 않거나 공공 주소 API가 오류를 반환한 경우"
          }
        },
        "summary": "주소 검색",
        "tags": [
          "Addresses"
        ]
      }
    },
    "/movies": {
      "get": {
        "description": "기준 시각과 가장 가까운 상영을 가진 영화 순으로 목록을 조회합니다. time은 정시 단위로 내림 보정되며, cursor가 있으면 다음 페이지를 조회합니다.",
        "operationId": "MovieController_list",
        "parameters": [
          {
            "name": "time",
            "required": false,
            "in": "query",
            "description": "영화 목록 정렬 기준 시각. 서버에서 정시 단위로 내림 보정 후 가까운 상영 순으로 정렬",
            "schema": {
              "example": "2026-04-28T10:30:00+09:00",
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "커서 페이지 크기",
            "schema": {
              "minimum": 1,
              "maximum": 50,
              "default": 20,
              "example": 20,
              "type": "number"
            }
          },
          {
            "name": "keyword",
            "required": false,
            "in": "query",
            "description": "영화 제목/장르/등급/설명 검색어",
            "schema": {
              "maxLength": 80,
              "example": "파묘",
              "type": "string"
            }
          },
          {
            "name": "cursor",
            "required": false,
            "in": "query",
            "description": "이전 응답의 nextCursor",
            "schema": {
              "maxLength": 500,
              "example": "eyJkaXN0YW5jZU1zIjoxMjAwMDAwfQ",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "커서 기반 영화 목록",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MovieListResultDto"
                }
              }
            }
          },
          "400": {
            "description": "time, limit, cursor 등 query 파라미터가 유효하지 않은 경우"
          }
        },
        "summary": "영화 목록 조회",
        "tags": [
          "Movies"
        ]
      }
    },
    "/theaters": {
      "get": {
        "description": "영화관 목록을 조회합니다. latitude와 longitude를 함께 전달하면 현재 위치와 가까운 영화관 순으로 정렬하고, 위치를 전달하지 않으면 기본 목록 순서로 반환합니다.",
        "operationId": "TheaterController_list",
        "parameters": [
          {
            "name": "latitude",
            "required": false,
            "in": "query",
            "description": "현재 위치 위도. longitude와 함께 전달하면 가까운 영화관 순으로 정렬",
            "schema": {
              "minimum": -90,
              "maximum": 90,
              "example": 37.5005,
              "type": "number"
            }
          },
          {
            "name": "longitude",
            "required": false,
            "in": "query",
            "description": "현재 위치 경도. latitude와 함께 전달하면 가까운 영화관 순으로 정렬",
            "schema": {
              "minimum": -180,
              "maximum": 180,
              "example": 127.0364,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "영화관 목록",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TheaterListResultDto"
                }
              }
            }
          },
          "400": {
            "description": "위도/경도 범위가 유효하지 않은 경우"
          }
        },
        "summary": "영화관 목록 조회",
        "tags": [
          "Theaters"
        ]
      }
    }
  },
  "info": {
    "title": "GC Movie Reservation Service API",
    "description": "영화 예매 서비스 백엔드 API 문서입니다.\n회원가입/로그인, 휴대전화 인증, 주소 검색, 영화 목록, 영화관 목록 API를 제공합니다.\nValidationPipe가 whitelist와 forbidNonWhitelisted를 사용하므로 문서에 없는 요청 필드는 거부됩니다.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "Health",
      "description": "서비스 상태 확인"
    },
    {
      "name": "Members",
      "description": "회원가입, 로그인, 비밀번호 및 휴대전화 인증"
    },
    {
      "name": "Addresses",
      "description": "공공 주소 API 기반 주소 검색"
    },
    {
      "name": "Movies",
      "description": "영화 목록과 상영 정보 조회"
    },
    {
      "name": "Theaters",
      "description": "영화관 목록과 위치 기반 정렬"
    }
  ],
  "servers": [],
  "components": {
    "schemas": {
      "HealthStatusDto": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true,
            "description": "서비스 정상 동작 여부"
          },
          "service": {
            "type": "string",
            "example": "gc-service",
            "description": "서비스 식별자"
          }
        },
        "required": [
          "ok",
          "service"
        ]
      },
      "CheckUserIdAvailabilityResultDto": {
        "type": "object",
        "properties": {
          "available": {
            "type": "boolean",
            "example": true,
            "description": "회원 아이디 사용 가능 여부"
          }
        },
        "required": [
          "available"
        ]
      },
      "RequestPhoneVerificationRequestDto": {
        "type": "object",
        "properties": {
          "phoneNumber": {
            "type": "string",
            "example": "01012345678",
            "pattern": "^\\d{10,11}$",
            "description": "인증 코드를 발급할 휴대전화번호"
          }
        },
        "required": [
          "phoneNumber"
        ]
      },
      "PhoneVerificationIssuedDto": {
        "type": "object",
        "properties": {
          "verificationId": {
            "type": "string",
            "example": "1",
            "description": "휴대전화 인증 요청 ID"
          },
          "code": {
            "type": "string",
            "example": "123456",
            "description": "개발 환경에서 클라이언트가 확인할 인증 코드"
          },
          "expiresAt": {
            "format": "date-time",
            "type": "string",
            "example": "2026-04-28T01:05:00.000Z",
            "description": "인증 코드 만료 시각"
          }
        },
        "required": [
          "verificationId",
          "code",
          "expiresAt"
        ]
      },
      "ConfirmPhoneVerificationRequestDto": {
        "type": "object",
        "properties": {
          "verificationId": {
            "type": "string",
            "example": "1",
            "description": "휴대전화 인증 요청 ID"
          },
          "phoneNumber": {
            "type": "string",
            "example": "01012345678",
            "pattern": "^\\d{10,11}$",
            "description": "인증 대상 휴대전화번호"
          },
          "code": {
            "type": "string",
            "example": "123456",
            "pattern": "^\\d{6}$",
            "description": "발급받은 6자리 인증 코드"
          }
        },
        "required": [
          "verificationId",
          "phoneNumber",
          "code"
        ]
      },
      "PhoneVerificationConfirmedDto": {
        "type": "object",
        "properties": {
          "verified": {
            "type": "boolean",
            "example": true,
            "description": "휴대전화 인증 완료 여부"
          }
        },
        "required": [
          "verified"
        ]
      },
      "SignupMemberRequestDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "example": "movie_user",
            "pattern": "^[a-z][a-z0-9_]{3,19}$",
            "description": "회원 로그인 ID"
          },
          "password": {
            "type": "string",
            "example": "password123!",
            "minLength": 8,
            "maxLength": 72,
            "description": "회원 비밀번호"
          },
          "name": {
            "type": "string",
            "example": "홍길동",
            "minLength": 1,
            "maxLength": 50,
            "description": "회원 이름"
          },
          "birthDate": {
            "type": "string",
            "example": "1990-01-01",
            "description": "생년월일. ISO date 문자열"
          },
          "phoneNumber": {
            "type": "string",
            "example": "01012345678",
            "pattern": "^\\d{10,11}$",
            "description": "휴대전화번호"
          },
          "address": {
            "type": "string",
            "example": "서울특별시 강남구 테헤란로 427",
            "minLength": 1,
            "maxLength": 255,
            "description": "회원 주소"
          },
          "phoneVerificationId": {
            "type": "string",
            "example": "1",
            "description": "인증 완료된 휴대전화 인증 요청 ID"
          }
        },
        "required": [
          "userId",
          "password",
          "name",
          "birthDate",
          "phoneNumber",
          "address",
          "phoneVerificationId"
        ]
      },
