# Runtime
NODE_ENV=development
LOG_LEVEL=INFO
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gc_project
DB_USER=gc_user
DB_PASSWORD=gc_password

# Redis
REDIS_URL=redis://localhost:6379

# Address search
# Use "local" for the bundled local JSON adapter.
# Use "juso" only when JUSO_API_KEY is configured.
ADDRESS_SEARCH_ADAPTER=local
JUSO_API_KEY=

# Auth
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600

# Seat hold
SEAT_HOLD_TTL_SECONDS=600

# Local payment adapter
LOCAL_PAYMENT_CALLBACK_URL=http://localhost:3000/payments/callback
LOCAL_PAYMENT_CALLBACK_DELAY_SECONDS=3

# Migrations
MIGRATIONS_RUN_ON_STARTUP=true

# Worker only
# Copy these values to .env-worker when running the worker process separately.
PAYMENT_OUTBOX_WORKER_ENABLED=true
PAYMENT_OUTBOX_WORKER_INTERVAL_MS=1000

# Admin
ADMIN_USER_ID=admin
ADMIN_PASSWORD=admin
ADMIN_ACCESS_TOKEN_TTL_SECONDS=900
